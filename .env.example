PORT=4000

# Use esta variavel no Render. Ela vem do banco PostgreSQL criado no Render.
DATABASE_URL=postgresql://usuario:senha@host:5432/nome_do_banco

# Render geralmente exige SSL para conexao externa.
# Para PostgreSQL local, use DB_SSL=false.
DB_SSL=true

# Alternativa para rodar local sem DATABASE_URL:
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=root
DB_PASSWORD=root
DB_DATABASE=db_blogpessoal
